# ===========================================
# Assemblee Deliberantes - Variables d'environnement
# ===========================================
# Copier ce fichier en .env.local et remplir les valeurs

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Institution (single-tenant — configurer pour cette institution)
NEXT_PUBLIC_INSTITUTION_NAME=
NEXT_PUBLIC_INSTITUTION_TYPE=   # commune|syndicat|cc|departement|asso
NEXT_PUBLIC_INSTITUTION_SIREN=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Services (SERVEUR UNIQUEMENT — jamais NEXT_PUBLIC_)
ANTHROPIC_API_KEY=
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Securite
NEXTAUTH_SECRET=
VOTE_HMAC_SECRET=
VOTE_ENCRYPTION_KEY=
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Assemblee Deliberantes

# Monitoring
SENTRY_DSN=
